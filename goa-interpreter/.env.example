# --- LiveKit (self-hosted via docker-compose, or LiveKit Cloud) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret-at-least-32-chars-long-please-change

# --- ASR ---
DEEPGRAM_API_KEY=

# --- Translation LLM ---
OPENAI_API_KEY=
TRANSLATION_MODEL=gpt-4o-mini

# --- TTS / Voice cloning ---
ELEVENLABS_API_KEY=
# Fallback voice used when a session has no cloned voice_id.
# "Rachel" public voice id; replace with one from your account if you prefer.
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# OmniVoice (k2-fsa) self-hosted via OmniVoice-local. Mount voices_dir into
# the container as its sample directory so cloned voices are reachable.
OMNIVOICE_URL=http://localhost:8000
VOICES_DIR=voices

# Default TTS provider when /session/start does not specify one.
# elevenlabs | omnivoice
DEFAULT_TTS_PROVIDER=elevenlabs

# --- Source language (master speaker). en | hi | es | ... ---
SOURCE_LANGUAGE=en

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
